{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "skill_name": "code-review",
  "skill_version": "1.0.0",
  "context_bundle": {
    "type": "object",
    "required": ["repository", "branch", "language", "description"],
    "properties": {
      "repository": {
        "type": "string",
        "description": "Repository name (e.g. platform-auth)"
      },
      "branch": {
        "type": "string",
        "description": "Branch name or PR reference (e.g. feature/oauth-refresh-fix)"
      },
      "language": {
        "type": "string",
        "description": "Primary programming language (e.g. TypeScript)"
      },
      "description": {
        "type": "string",
        "description": "What changed and why -- enough context for the reviewer to understand the goal"
      },
      "areas_of_concern": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Specific areas the sender is uncertain about and wants the reviewer to focus on"
      },
      "related_tickets": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Related issue or ticket IDs (e.g. ZD-4521)"
      }
    },
    "additionalProperties": true
  },
  "response_bundle": {
    "type": "object",
    "required": ["status", "summary", "blocking_feedback"],
    "properties": {
      "status": {
        "type": "string",
        "enum": ["approved", "changes_requested", "questions"],
        "description": "approved -- good to merge; changes_requested -- fix blocking issues first; questions -- need clarification before reviewing"
      },
      "summary": {
        "type": "string",
        "description": "Overall assessment in 1-2 sentences"
      },
      "blocking_feedback": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Issues that must be fixed before merging (may be empty)"
      },
      "advisory_feedback": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Suggestions and style notes that are non-blocking"
      },
      "questions": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Clarifying questions for the sender"
      }
    },
    "additionalProperties": true
  }
}
